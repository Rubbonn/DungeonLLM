LLM_MODEL=your_preferred_model
LLM_PROVIDER=the_provider_for_the_model
# Additional variables provider specific
NVIDIA_API_KEY=nvidia_api_key_placeholder
OLLAMA_HOST=ollama_custom_host
OLLAMA_API_KEY=ollama_api_key_for_cloud

# transformers serve — OpenAI-compatible local server
# Run: pip install transformers[serving] && transformers serve
# Then set these variables to use it as the LLM backend:
# LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# LLM_PROVIDER=openai
# OPENAI_API_KEY=fake
# OPENAI_BASE_URL=http://localhost:8000/v1